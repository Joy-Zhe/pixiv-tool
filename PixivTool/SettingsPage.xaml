<Page x:Class="PixivTool.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Title="SettingsPage"
      MinHeight="600"
      MinWidth="720"
      Height="600"
      Width="720">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="100" />
            <ColumnDefinition Width="400" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="80" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="200" />
            <RowDefinition Height="40" />
            <RowDefinition Height="20" />
            <RowDefinition Height="40" />
            <RowDefinition Height="20" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <Label VerticalAlignment="Center" Grid.Column="1" Grid.Row="1" Content="Rank Path" />
        <Label VerticalAlignment="Center" Grid.Column="1" Grid.Row="3" Content="PID Path" />
        <Label VerticalAlignment="Center" Grid.Column="1" Grid.Row="5" Content="Cookie" />

        <TextBox Grid.Column="2"
                 Grid.Row="1"
                 VerticalContentAlignment="Center"
                 Text="{Binding RankDownloadPath, UpdateSourceTrigger=PropertyChanged}" />
        <TextBox Grid.Column="2"
                 Grid.Row="3"
                 VerticalContentAlignment="Center"
                 Text="{Binding PidDownloadPath, UpdateSourceTrigger=PropertyChanged}" />
        <TextBox Grid.Column="2"
                 Grid.Row="5"
                 VerticalContentAlignment="Center"
                 Text="{Binding CookieRawMessage, UpdateSourceTrigger=PropertyChanged}" />

        <Button Grid.Column="4" Grid.Row="1" Content="Apply" Command="{Binding ApplyRankPathCommand}" />
        <Button Grid.Column="4" Grid.Row="3" Content="Apply" Command="{Binding ApplyPidPathCommand}" />
        <Button Grid.Column="4" Grid.Row="5" Content="Save" Command="{Binding SaveCommand}" />
    </Grid>
</Page>

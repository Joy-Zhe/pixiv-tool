<Window x:Class="PixivTool.Views.DownloadProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Download Progress"
        Width="460"
        Height="180"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="ToolWindow">
    <Border Padding="16" Background="{StaticResource CardBrush}">
        <StackPanel>
            <TextBlock x:Name="TitleText"
                       Text="Downloading..."
                       FontSize="18"
                       FontWeight="SemiBold"
                       Margin="0,0,0,10" />
            <ProgressBar x:Name="Progress"
                         Minimum="0"
                         Maximum="100"
                         Height="18"
                         Value="0" />
            <TextBlock x:Name="StatusText"
                       Margin="0,10,0,0"
                       Text="Preparing..."
                       Foreground="#4A6280"
                       TextWrapping="Wrap" />
        </StackPanel>
    </Border>
</Window>
